# ── .env.example – copy to .env and fill in your values ──────────────────────

# Device: "cuda" (NVIDIA GPU) or "cpu"
DEVICE=cuda

# Which trained model version to load on startup.
# This must match the directory name under models/, e.g. "syslog_gmm_k5_v1"
DEFAULT_MODEL_VERSION=default

# Whether to run warm-up predictions on startup (recommended: true)
WARM_UP=true

# Number of dummy samples for warm-up
WARM_UP_SAMPLES=10

# FastAPI / uvicorn log level
LOG_LEVEL=info

# CORS – restrict in production
CORS_ORIGINS=*
